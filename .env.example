# ============================================
# 纳灵虚拟办公室 - 环境变量配置
# ============================================
#
# 复制此文件为 .env 后修改对应值
# cp .env.example .env
#
# Docker Compose 使用:
#   docker-compose --env-file .env up -d
#

# ============================================
# 应用基础配置
# ============================================

# 应用名称
APP_TITLE=纳灵虚拟办公室

# 应用版本 (显示在页脚)
APP_VERSION=v1.0.0

# 部署端口 (Docker 映射到主机的端口)
APP_PORT=3000

# 应用基础路径 (如果部署在子路径)
# 例如: /office/
# 默认: /
APP_BASE_URL=/

# 时区
TZ=Asia/Shanghai

# ============================================
# 数据源配置
# ============================================

# 数据源类型: local (本地) | api (远程API) | mock (模拟数据)
DATA_SOURCE=local

# API 端点 (当 DATA_SOURCE=api 时使用)
# API_ENDPOINT=https://api.example.com/office/v1

# API 认证密钥 (可选)
# API_KEY=your-api-key-here

# ============================================
# 功能开关
# ============================================

# 是否启用实时状态模拟 (true/false)
ENABLE_STATUS_SIMULATION=true

# 状态更新间隔 (毫秒)
STATUS_UPDATE_INTERVAL=30000

# 是否启用数据持久化 (LocalStorage)
ENABLE_DATA_PERSISTENCE=true

# 是否启用通知系统
ENABLE_NOTIFICATIONS=true

# ============================================
# Docker 部署配置
# ============================================

# Docker 镜像标签
# DOCKER_TAG=latest

# 是否启用 Watchtower 自动更新
# ENABLE_WATCHTOWER=true

# ============================================
# 后端服务配置 (可选)
# ============================================

# MongoDB 连接 (当使用后端服务时)
# DATABASE_URL=mongodb://admin:password@localhost:27017/office

# Redis 连接 (当使用后端服务时)
# REDIS_URL=redis://:password@localhost:6379

# JWT 密钥 (必须修改!)
# JWT_SECRET=change-this-to-a-random-secret-key

# ============================================
# HTTPS 配置 (生产环境)
# ============================================

# 是否启用 HTTPS
# ENABLE_HTTPS=false

# SSL 证书路径 (Docker 内部路径)
# SSL_CERT=/etc/nginx/ssl/cert.pem
# SSL_KEY=/etc/nginx/ssl/key.pem

# ============================================
# 域名配置
# ============================================

# 部署域名
# DOMAIN=office.example.com

# 是否启用 HTTPS (Let's Encrypt)
# ENABLE_LETSENCRYPT=true
# LETSENCRYPT_EMAIL=admin@example.com

# ============================================
# 日志与监控
# ============================================

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 是否启用详细错误日志
# ENABLE_ERROR_DETAILS=false

# Sentry DSN (错误监控)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# 性能优化
# ============================================

# 是否启用 Service Worker (PWA)
ENABLE_SERVICE_WORKER=true

# 最大 WebSocket 连接数
# MAX_WS_CONNECTIONS=100

# 静态资源缓存时间 (秒)
# STATIC_CACHE_MAX_AGE=31536000
